#include<iostream>
using namespace std ;

class Stack 
{
    int top = -1 ;
    public:
    static const int size = 6 ; 
    int arr[size] ;
    
    
    bool isEmpty()
    {
        return top == -1 ;
    }
    bool isFull()
    {
        return (top == size-1) ;
    }
 void push(int value)
 {
     if(isFull())
     {
         cout << "Stack is Full" << endl ;
         return ;
     }
     top++ ;
     arr[top] = value ;
     
 }
 int pop()
 {
     if(isEmpty())
     {
         cout << "Stack is EMPTY !!!" << endl ;
         return -1 ;
     }
     int temp = arr[top] ;
     top-- ;
     return arr[temp] ;
 }
 void display()
{
    if(isEmpty())
    {
        cout << "Stack is Empty!!!" << endl ;
        return ;
    }
    for(int i = 0 ; i <= top ; i++)
    {
        cout << "  ___" << endl ;
        cout << " | " << arr[i]  << " | " << endl ;
       
    }
    cout << endl ;
}
int peek()
{
    if(isEmpty())
    {
        cout << "Stack is EMPYT!!!" << endl ;
        return -1 ;
    }
    return arr[top] ;
}
} ;
int main()
{
    Stack s ;
    s.push(12) ;
    s.push(23) ;
    s.push(56) ;
    s.push(76) ;
    s.push(89) ;
    s.display() ;
    s.pop() ;
    s.pop() ;
    s.display() ;
    s.pop() ;
    s.pop() ;
    s.pop() ;
    int top_element = s.peek() ;
    cout << top_element << endl ;  
}

