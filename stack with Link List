#include<iostream>
using namespace std ; 
class Node
{
   public:
    int data ;
    Node* next ;
 
    Node(int data)
    {
        this->data = data ;
        next = NULL ;
    }
} ;
class Stack  
{
    
    Node* top = NULL ;
    public:
    
    bool isEmpty()
    {
        return top == NULL ;
    }
   // As Linked list are dynamically allocated memory so no need of full funtion as it depends upon how much RAM Computer has.
    
void push(int val)
{
    Node* newNode = new Node(val) ;
     newNode->next = top ;
     top = newNode ;
}
void pop()
{
    if(isEmpty())
    {
        cout << "Stack is Empty!!!" << endl ;
        return ;
    }
       Node* temp = top ;
   top = top->next ;
    cout << "Value at Top Removed: "<< temp->data << endl ;
    delete temp ;
}
void display()
{
    if(isEmpty())
    {
        cout << "Stack is Empty!!!" << endl ;
        return ;
    }
    Node* temp = top ;
    while(temp != NULL )
    {
        cout << temp->data << " -> " ;
        temp = temp->next ;
    }
    cout << "NULL" << endl ;
}
int peek()
{
    if(isEmpty())
    {
        return -1 ;
    }
    return top->data ; 
}
    
};
int main()
{
    Stack s ;
    s.push(12) ;
    s.push(45) ;
    s.push(76) ;
    s.push(31) ;
    s.push(7) ;
    s.display() ;
    s.pop() ;
    s.pop() ;
    s.display() ;
    s.pop() ;
    s.pop() ;
    s.pop() ;
    s.display() ;
    int top_element = s.peek() ;
    cout << top_element << endl ;
    
    return 0 ;
}

